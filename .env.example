# ── Core ────────────────────────────────────────────────────────────────
ENV=local                       # local | staging | prod
PUBLIC_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
SENTRY_DSN=

# ── Database / Redis ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bm:bm@localhost:5432/bm_usa_proxy
REDIS_URL=redis://localhost:6379/0

# ── Telegram bot ────────────────────────────────────────────────────────
BOT_TOKEN=                       # from @BotFather
BOT_WEBHOOK_SECRET=change-me     # X-Telegram-Bot-Api-Secret-Token
OPS_ALERT_CHAT_ID=               # operators' TG chat for system alerts

# ── Admin auth ──────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-in-prod-please-32bytes-min
ADMIN_JWT_TTL_MIN=30
ADMIN_REFRESH_TTL_DAYS=14
SEED_ADMIN_EMAIL=admin@bmusproxy.local
SEED_ADMIN_PASSWORD=             # required for seed; NEVER a default on prod

# ── Encryption (proxy credentials at rest) ──────────────────────────────
# generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_KEY=

# ── iproxy.online (Stage 3) ─────────────────────────────────────────────
IPROXY_API_KEY=
IPROXY_BASE_URL=https://api.iproxy.online

# ── Crypto payment provider (Stage 3, DG-1) ─────────────────────────────
PAYMENT_PROVIDER=mock            # mock | bitpay | coinbase | cryptomus
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# ── Feature flags ───────────────────────────────────────────────────────
FEATURE_REAL_PAYMENTS=false      # false until Stage 3 (Mock provider drives checkout)
SEED_DEV_FIXTURES=true           # seed demo users/connections/orders on local/staging only
